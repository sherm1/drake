load("//tools/lint:lint.bzl", "add_lint_tests")

# This is a smoke test on a nanobind binding, as a sanity check of the build.

cc_binary(
    name = "sample_module.so",
    srcs = ["sample_module.cc"],
    linkshared = True,
    linkstatic = True,
    deps = [
        "//tools/workspace/nanobind",
