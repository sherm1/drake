)

py_test(
    name = "sample_module_test",
    srcs = ["sample_module_test.py"],
    data = [":sample_module.so"],
    imports = ["."],
    main = "sample_module_test.py",
    deps = ["//bindings/pydrake/common/test_utilities/scipy_stub"],
)

add_lint_tests()
